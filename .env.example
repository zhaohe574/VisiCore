# 视枢 Docker 安装示例。复制为 .env 后按需调整镜像和管理端监听地址。
# PostgreSQL 和 MediaMTX 已内置于唯一的核心容器，不需要额外启动容器。
ADMIN_HTTP_BIND_ADDRESS=127.0.0.1
ADMIN_HTTP_PORT=8080
# HTTPS 默认关闭；启用前必须准备由受信任 CA 签发的证书和私钥，详见 deploy/core/tls/README.md。
ADMIN_HTTPS_BIND_ADDRESS=127.0.0.1
ADMIN_HTTPS_PORT=8443
VISICORE_HTTPS_ENABLED=false
VISICORE_TLS_DIRECTORY=./deploy/core/tls
VISICORE_TLS_CERTIFICATE_FILE=/run/visicore/tls/tls.crt
VISICORE_TLS_PRIVATE_KEY_FILE=/run/visicore/tls/tls.key
# 生产升级必须改为 GitHub Release 的 release-descriptor.json 中带 sha256 的不可变引用；源码验证可改为空并执行 docker compose build。
# 下面的版本标签仅用于首次体验和开发，不应作为 Host Agent 的升级基线。
VISICORE_CORE_IMAGE=visicore/visicore-core:0.1.6
# 发行治理只接受该 GitHub 仓库下的文档、Release、Actions 与证据外链；不会向 GitHub 发起写入。
VISICORE_RELEASE_GOVERNANCE_REPOSITORY_URL=https://github.com/zhaohe574/VisiCore
# 这些卷名是升级兼容契约。已有部署升级时必须保持不变；仅新实例可改为独立名称。
VISICORE_POSTGRES_VOLUME=visicore_postgres-data
VISICORE_CONFIG_VOLUME=visicore_visicore-config
VISICORE_EXPORTS_VOLUME=visicore_api-exports
VISICORE_BACKUPS_VOLUME=visicore_visicore-backups
VISICORE_NETWORK=visicore-network
