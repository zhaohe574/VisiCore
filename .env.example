# Docker 本地安装示例。复制为 .env 后必须替换所有 change-me 值。
# 管理端默认只绑定回环地址；公网部署需要独立 TLS 反向代理与密钥管理。
POSTGRES_DB=video_platform
POSTGRES_USER=video_platform
POSTGRES_PASSWORD=change-me-use-a-long-random-password
ADMIN_HTTP_BIND_ADDRESS=127.0.0.1
ADMIN_HTTP_PORT=8080

# 以下变量只在启用 --profile edge 的 ONVIF／RTSP 边缘服务时需要。
PLATFORM_BASE_URI=https://video-platform.example.invalid/
STREAM_GATEWAY_NAME=default
STREAM_GATEWAY_CONTROL_TOKEN=change-me-use-an-independent-random-token
STREAM_GATEWAY_COMMAND_TOKEN=change-me-use-an-independent-random-token
STREAM_GATEWAY_WORKER_TOKEN=change-me-use-an-independent-random-token
MEDIAMTX_PUBLISHER_USERNAME=relay
MEDIAMTX_PUBLISHER_PASSWORD=change-me-use-an-independent-random-password
MEDIAMTX_HLS_READER_USERNAME=hlsproxy
MEDIAMTX_HLS_READER_PASSWORD=change-me-use-an-independent-random-password
ONVIF_EDGE_ACCESS_TOKEN=change-me-use-a-one-time-worker-token

# CI 可通过这两个变量进行非交互 setup；日常安装应留空并在容器中交互输入。
SETUP_USERNAME=
SETUP_PASSWORD=
