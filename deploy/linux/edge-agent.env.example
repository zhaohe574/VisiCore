# 复制为 deploy/linux/.env。首次配置通过 http://127.0.0.1:18081 完成，不能在此文件写入中心地址、注册码或发行密钥。
EDGE_STATE_DIRECTORY=/var/lib/visicore/edge-node/state
EDGE_HOST_EXCHANGE_DIRECTORY=/var/lib/visicore/edge-node/host-exchange
EDGE_HOST_CONFIG_DIRECTORY=/var/lib/visicore/edge-node/config
EDGE_CONFIG_PORT=18081
EDGE_HEARTBEAT_INTERVAL_SECONDS=30
